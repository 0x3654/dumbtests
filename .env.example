# Twitter cookies (Safari: Develop → Web Inspector → Storage → Cookies → x.com)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# z.ai API key (api.z.ai)
AI_API_KEY=
# Redis (default works with compose)
REDIS_URL=redis://redis:6379
# Analyzer internal URL (default works with compose)
ANALYZER_URL=http://analyzer:8001
# Public site URL for OG image generation (set to your domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
