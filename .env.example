# Twitter cookies (Safari: Develop → Web Inspector → Storage → Cookies → x.com)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# z.ai API key (api.z.ai)
AI_API_KEY=
# Admin key for /debug and DELETE /cache endpoints
ADMIN_KEY=
# CORS allowed origins (comma-separated, default: https://0x3654.com)
CORS_ORIGINS=https://0x3654.com
# Redis (default works with compose)
REDIS_URL=redis://redis:6379
# Analyzer internal URL (default works with compose)
ANALYZER_URL=http://analyzer:8001
# Public site URL for OG image generation (set to your domain in prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Base path if app is served under a subpath (e.g. /topbottom)
NEXT_PUBLIC_BASE_PATH=/topbottom
